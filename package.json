{
  "name": "pds-blocks-pro",
  "version": "2.0.0",
  "description": "Phenix Design System User Interface / Front-End Framework - for WordPress.",
  "author": "Abdullah.Ramadan <elampratorabdallah14@gmail.com> (https://phenixthemes.com)",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/EngCode/pds-blocks-pro.git"
  },
  "main": "/assets/css/phenix.css",
  "scripts": {
    "phenix-start": "concurrently --kill-others \"npm run phenix-sass-watch\" \"npm run phenix-ts-watch\" \"npm run phenix-blocks\"",
    "phenix-ts": "webpack --config typescript.webpack.js",
    "phenix-ts-watch": "webpack --config typescript.webpack.js --watch",
    "phenix-sass": "sass src/sass:assets/css --style=compressed --source-map",
    "phenix-sass-watch": "sass --watch src/sass:assets/css --style=compressed --source-map --poll",
    "phenix-sass-debug": "sass --watch src/sass:assets/css --style=compressed --source-map --verbose",
    "phenix-blocks": "wp-scripts start",
    "phenix-ext": "webpack --config typescript.webpack.ext.js",
    "phenix-ext-watch": "webpack --config typescript.webpack.ext.js --watch",
    "animate-sass": "sass src/animations:assets/css/animations --style=compressed",
    "animate-sass-watch": "sass --watch src/animations:assets/css/animations --style=compressed"
  },
  "devDependencies": {
    "@wordpress/scripts": "^30.0.0",
    "concurrently": "^9.0.0",
    "glob": "^11.0.0",
    "sass": "^1.80.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.0",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {}
}
